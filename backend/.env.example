# Database
DATABASE_URL=postgresql://app:app@localhost:5432/appdb

# Auth0
AUTH0_ISSUER_BASE_URL=https://<tenant>.auth0.com/
AUTH0_AUDIENCE=https://api.yourapp.com

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_FORCE_PATH_STYLE=true
S3_BUCKET_RAW=raw
S3_BUCKET_EXPORTS=exports

# Optional: SQS for production (use BullMQ locally)
SQS_QUEUE_URL=

# API
PORT=3001
FRONTEND_URL=http://localhost:3000

# Retention: auto-delete raw/exports after N hours (default 72)
RETENTION_HOURS=72
RETENTION_DISABLED=false

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
PRO_PRICE_CENTS=1999
PRO_PRICE_INTERVAL=month

# Local dev only: bypass Auth0 (set AUTH_DISABLED=true)
AUTH_DISABLED=false
